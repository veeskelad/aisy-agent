# Aisy — environment template. Copy to `.env` and fill in.
#   cp .env.example .env
# `.env` is git-ignored; secrets never go in the image or the repo.
# `aisy init` can also create/validate this interactively (terminal-side pairing).

# ── Telegram (required) ──────────────────────────────────────────────────────
# Bot token from @BotFather. Chat id is set by `aisy init` pairing (or paste it
# here for the non-interactive / Docker path).
AISY_TELEGRAM_BOT_TOKEN=
AISY_TELEGRAM_CHAT_ID=

# ── LLM provider (at least one key required) ─────────────────────────────────
# Set the key for the provider you use. Catalog: anthropic, openai, deepseek,
# openrouter, qwen, glm, gemini, custom (OpenAI-compatible), claude-cli.
AISY_PROVIDER_ANTHROPIC_KEY=
# AISY_PROVIDER_OPENAI_KEY=
# AISY_PROVIDER_DEEPSEEK_KEY=
# AISY_PROVIDER_OPENROUTER_KEY=
# AISY_PROVIDER_QWEN_KEY=
# AISY_PROVIDER_GLM_KEY=
# AISY_PROVIDER_GEMINI_KEY=
# AISY_PROVIDER_CUSTOM_KEY=
# Default model (overrides providers.json default). e.g. claude-sonnet-4-6
# AISY_PROVIDER_MODEL=

# ── Optional knobs (sensible defaults if unset) ──────────────────────────────
# Session budget (USD) for the cost bar; per-agent caps live in providers.json.
# AISY_BUDGET_USD=5
# Sandboxed bash: set an image to enable the bash tool (mounts host Docker socket
# — trusted hosts only). gVisor (runsc) preferred where present.
# AISY_SANDBOX_IMAGE=
# AISY_SANDBOX_GVISOR=1
# Prefix caching on by default; set 0 to disable.
# AISY_PREFIX_CACHE=1
# Nightly memory consolidation run time (HH:MM, local).
# AISY_NIGHTLY_AT=03:30
# Goal-loop backstop (anti-runaway).
# AISY_GOAL_MAX_ITERATIONS=25
# AISY_GOAL_TOKEN_CEILING=500000
# AISY_GOAL_DOLLAR_CEILING=5
# Memory tree location (Docker mounts /data).
# AISY_MEMORY_ROOT=
